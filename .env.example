# Server
PORT=3000
NODE_ENV=development
HOST=0.0.0.0

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/gray_refer

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Shopify App credentials (used for multi-shop OAuth later)
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# Reward config defaults (overridable per shop)
DEFAULT_REFERRAL_THRESHOLD=10
DEFAULT_REWARD_VALUE=1000
DEFAULT_VALIDATION_DELAY_DAYS=7

# Frontend URL (for referral links)
FRONTEND_URL=https://refer.yourapp.com
