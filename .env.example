# Server
PORT=3000
NODE_ENV=development
HOST=0.0.0.0

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/gray_refer

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Shopify App credentials (from partners.shopify.com → your app → API credentials)
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# Public URL of this backend server (used for webhook registration)
BACKEND_PUBLIC_URL=https://api.yourapp.com

# Frontend URL (for referral links and OAuth redirect)
FRONTEND_URL=https://refer.yourapp.com

# AES-256-GCM key for encrypting WhatsApp credentials — 64 hex chars (32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_hex_char_encryption_key

# Resend (email fallback)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=referrals@yourapp.com
